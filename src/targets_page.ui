<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="SimplesyncTargetsPage" parent="AdwNavigationPage">
    <property name="title" translatable="yes">SimpleSync</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="start">
              <object class="GtkButton" id="add_button">
                <property name="icon-name">list-add-symbolic</property>
                <property name="tooltip-text" translatable="yes">Add Target</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkMenuButton">
                <property name="icon-name">open-menu-symbolic</property>
                <property name="menu-model">primary_menu</property>
                <property name="primary">True</property>
                <property name="tooltip-text" translatable="yes">Menu</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="push_all_button">
                <property name="icon-name">emblem-synchronizing-symbolic</property>
                <property name="tooltip-text" translatable="yes">Push All</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkStack" id="content_stack">
            <child>
              <object class="GtkStackPage">
                <property name="name">no_account</property>
                <property name="child">
                  <object class="AdwStatusPage" id="no_account_status">
                    <property name="icon-name">system-users-symbolic</property>
                    <property name="title" translatable="yes">No Account</property>
                    <property name="description" translatable="yes">Connect your Nextcloud account to start syncing</property>
                    <property name="child">
                      <object class="GtkButton" id="setup_account_button">
                        <property name="label" translatable="yes">Set Up Account</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="suggested-action"/>
                          <class name="pill"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">empty</property>
                <property name="child">
                  <object class="AdwStatusPage" id="empty_status">
                    <property name="icon-name">folder-remote-symbolic</property>
                    <property name="title" translatable="yes">No Targets</property>
                    <property name="description" translatable="yes">Add a sync target to get started</property>
                    <property name="child">
                      <object class="GtkButton" id="empty_add_button">
                        <property name="label" translatable="yes">Add Target</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="suggested-action"/>
                          <class name="pill"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">list</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="vexpand">True</property>
                    <property name="hscrollbar-policy">never</property>
                    <child>
                      <object class="AdwClamp">
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <child>
                          <object class="GtkListBox" id="targets_list">
                            <style>
                              <class name="boxed-list"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </template>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Account</attribute>
        <attribute name="action">app.account</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_About SimpleSync</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
</interface>
